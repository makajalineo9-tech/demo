<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.demo.RestaurantController"
           style="-fx-background-color: #f8fafc;">  <!-- clean light neutral bg -->

    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <VBox alignment="TOP_CENTER" spacing="28" maxWidth="720">

        <!-- Header / Title -->
        <Label text="Dinner Order"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

        <HBox spacing="40" alignment="TOP_LEFT">

            <!-- Left: Main Dishes -->
            <VBox spacing="20" styleClass="section-card">
                <Label text="MAIN DISHES" styleClass="section-title"/>

                <CheckBox fx:id="chkPap" text="Pap and Meat - M70"/>
                <CheckBox fx:id="chkRice" text="Rice and Chicken - M85"/>
                <CheckBox fx:id="chkChinese" text="Chinese Food - M120"/>
            </VBox>

            <!-- Right: Desserts -->
            <VBox spacing="20" styleClass="section-card">
                <Label text="DESSERTS" styleClass="section-title"/>

                <CheckBox fx:id="chkCustard" text="Custard and Jelly - M40"/>
                <CheckBox fx:id="chkChocolate" text="Chocolate Cake Slice - M35"/>
                <CheckBox fx:id="chkCupcake" text="Cupcake - M25"/>
            </VBox>

        </HBox>

        <!-- Drinks + Summary Section -->
        <VBox spacing="24" styleClass="section-card">

            <HBox alignment="CENTER_LEFT" spacing="40">
                <VBox spacing="8">
                    <Label text="DRINKS" styleClass="input-label"/>
                    <ComboBox fx:id="cmbDrinks" promptText="Choose drink" prefWidth="220"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="TOTAL AMOUNT" styleClass="input-label"/>
                    <TextField fx:id="txtTotal" editable="false" styleClass="readonly-field"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="40">
                <VBox spacing="8">
                    <Label text="AMOUNT TENDERED" styleClass="input-label"/>
                    <TextField fx:id="txtTendered" styleClass="input-field"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="CHANGE" styleClass="input-label"/>
                    <TextField fx:id="txtChange" editable="false" styleClass="readonly-field"/>
                </VBox>
            </HBox>

            <Label fx:id="lblTime" text="Time: --:-- --" styleClass="footer-label"/>

        </VBox>

        <!-- Action Buttons -->
        <HBox alignment="CENTER" spacing="20">
            <Button text="TOTAL AMOUNT" onAction="#calculateTotal"
                    styleClass="btn-primary" minWidth="160"/>
            <Button text="CHANGE" onAction="#calculateChange"
                    styleClass="btn-primary" minWidth="160"/>
            <Button text="RESET" onAction="#reset"
                    styleClass="btn-secondary" minWidth="160"/>
            <Button text="EXIT" onAction="#exit"
                    styleClass="btn-danger" minWidth="160"/>
        </HBox>

    </VBox>

    <!-- ──────────────────────────────────────────────── -->
    <!--                   STYLES                        -->
    <!-- ──────────────────────────────────────────────── -->
    <style>
        .section-card {
        -fx-background-color: white;
        -fx-background-radius: 16;
        -fx-border-radius: 16;
        -fx-border-color: #e5e7eb;
        -fx-border-width: 1;
        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 16, 0, 0, 4);
        -fx-padding: 28 24 28 24;
        }
        .section-title {
        -fx-font-size: 18px;
        -fx-font-weight: 700;
        -fx-text-fill: #111827;
        }
        .input-label {
        -fx-font-size: 14px;
        -fx-font-weight: 500;
        -fx-text-fill: #374151;
        }
        .input-field, .readonly-field {
        -fx-background-color: #f9fafb;
        -fx-background-radius: 10;
        -fx-border-color: #d1d5db;
        -fx-border-radius: 10;
        -fx-border-width: 1.2;
        -fx-padding: 12;
        -fx-font-size: 15px;
        -fx-prompt-text-fill: #9ca3af;
        }
        .readonly-field {
        -fx-background-color: #f3f4f6;
        -fx-text-fill: #111827;
        -fx-font-weight: bold;
        }
        .input-field:focused {
        -fx-background-color: white;
        -fx-border-color: #0d9488;
        -fx-border-width: 2;
        -fx-effect: dropshadow(gaussian, #0d948844, 10, 0, 0, 0);
        }
        .btn-primary {
        -fx-background-color: #0d9488;   /* teal accent – feels fresh for food app */
        -fx-text-fill: white;
        -fx-font-size: 15px;
        -fx-font-weight: 600;
        -fx-background-radius: 12;
        -fx-padding: 14 32;
        -fx-cursor: hand;
        }
        .btn-primary:hover {
        -fx-background-color: #0f766e;
        }
        .btn-secondary {
        -fx-background-color: transparent;
        -fx-border-color: #d1d5db;
        -fx-border-width: 2;
        -fx-text-fill: #374151;
        -fx-font-size: 15px;
        -fx-font-weight: 500;
        -fx-background-radius: 12;
        -fx-padding: 14 32;
        -fx-cursor: hand;
        }
        .btn-secondary:hover {
        -fx-background-color: #f3f4f6;
        -fx-border-color: #9ca3af;
        }
        .btn-danger {
        -fx-background-color: #ef4444;
        -fx-text-fill: white;
        -fx-font-size: 15px;
        -fx-font-weight: 600;
        -fx-background-radius: 12;
        -fx-padding: 14 32;
        -fx-cursor: hand;
        }
        .btn-danger:hover {
        -fx-background-color: #dc2626;
        }
        .footer-label {
        -fx-font-size: 13px;
        -fx-text-fill: #6b7280;
        -fx-font-style: italic;
        }
    </style>

</StackPane>